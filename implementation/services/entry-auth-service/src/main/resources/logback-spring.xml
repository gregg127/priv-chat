<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <springProfile name="default,dev,prod">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder class="net.logstash.logback.encoder.LogstashEncoder">
        <includeMdcKeyName>ip</includeMdcKeyName>
        <includeMdcKeyName>eventType</includeMdcKeyName>
        <includeMdcKeyName>username</includeMdcKeyName>
      </encoder>
    </appender>

    <root level="INFO">
      <appender-ref ref="STDOUT" />
    </root>

    <logger name="com.privchat" level="DEBUG" additivity="false">
      <appender-ref ref="STDOUT" />
    </logger>
  </springProfile>

  <!-- Simpler logging for tests -->
  <springProfile name="test">
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
      <encoder>
        <pattern>%d{HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
      </encoder>
    </appender>

    <root level="WARN">
      <appender-ref ref="STDOUT" />
    </root>

    <logger name="com.privchat" level="DEBUG" additivity="false">
      <appender-ref ref="STDOUT" />
    </logger>
  </springProfile>

</configuration>
